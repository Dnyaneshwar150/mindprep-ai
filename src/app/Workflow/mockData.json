{
  "question": {
    "id": "q2",
    "label": "How can you improve focus and concentration?",
    "answer": {
      "id": "a2",
      "label": "Improving focus involves eliminating distractions, training the mind, and creating an optimal work environment.",
      "mainPointHeadings": [
        {
          "id": "mph2_1",
          "label": "I. Create a Distraction-Free Environment",
          "mainPoints": [
            {
              "id": "mp2_1_1",
              "label": "Turn off notifications",
              "subPoints": [
                {
                  "id": "sp2_1_1_1",
                  "label": "Silence mobile and desktop alerts",
                  "explanation": {
                    "id": "exp2_1_1_1",
                    "label": "Reduces unnecessary interruptions that break concentration.",
                    "source": "https://example.com/focus-distractions"
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "mph2_2",
          "label": "II. Practice Mindfulness and Meditation",
          "mainPoints": [
            {
              "id": "mp2_2_1",
              "label": "Engage in daily meditation",
              "subPoints": [
                {
                  "id": "sp2_2_1_1",
                  "label": "Practice 10 minutes of breathing meditation",
                  "explanation": {
                    "id": "exp2_2_1_1",
                    "label": "Trains the brain to resist distractions and improve attention span.",
                    "source": "https://example.com/meditation-benefits"
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "mph2_3",
          "label": "III. Use Focus Techniques",
          "mainPoints": [
            {
              "id": "mp2_3_1",
              "label": "Try the 5-Second Rule",
              "subPoints": [
                {
                  "id": "sp2_3_1_1",
                  "label": "Count backward from 5 before starting a task",
                  "explanation": {
                    "id": "exp2_3_1_1",
                    "label": "Builds momentum and overcomes procrastination.",
                    "source": "https://example.com/5-second-rule"
                  }
                }
              ]
            },
            {
              "id": "mp2_3_2",
              "label": "Use Noise-Cancelling Headphones"
            }
          ]
        },
        {
          "id": "mph2_4",
          "label": "IV. Optimize Nutrition and Sleep",
          "mainPoints": [
            {
              "id": "mp2_4_1",
              "label": "Eat brain-boosting foods",
              "subPoints": [
                {
                  "id": "sp2_4_1_1",
                  "label": "Include foods like blueberries, nuts, and fish",
                  "explanation": {
                    "id": "exp2_4_1_1",
                    "label": "Supports memory and mental clarity.",
                    "source": "https://example.com/brain-foods"
                  }
                }
              ]
            },
            {
              "id": "mp2_4_2",
              "label": "Get 7-9 hours of quality sleep"
            }
          ]
        }
      ]
    }
  }
